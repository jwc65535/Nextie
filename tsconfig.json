{
  "files": [],
  "references": [
    { "path": "packages/core" },
    { "path": "packages/data" },
    { "path": "packages/component" },
    { "path": "packages/layout" },
    { "path": "packages/ui" },
    { "path": "packages/form" },
    { "path": "packages/grid" },
    { "path": "packages/dd" },
    { "path": "packages/app" },
    { "path": "packages/fx" },
    { "path": "packages/theme" }
  ],
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "noImplicitAny": true,
    "noImplicitThis": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strictBindCallApply": true,
    "strictPropertyInitialization": true,
    "strictBuiltinIteratorReturn": true,
    "alwaysStrict": true,
    "useUnknownInCatchVariables": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "exactOptionalPropertyTypes": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "paths": {
      "@ext-ts/core": ["packages/core/src/index.ts"],
      "@ext-ts/data": ["packages/data/src/index.ts"],
      "@ext-ts/component": ["packages/component/src/index.ts"],
      "@ext-ts/layout": ["packages/layout/src/index.ts"],
      "@ext-ts/ui": ["packages/ui/src/index.ts"],
      "@ext-ts/form": ["packages/form/src/index.ts"],
      "@ext-ts/grid": ["packages/grid/src/index.ts"],
      "@ext-ts/dd": ["packages/dd/src/index.ts"],
      "@ext-ts/app": ["packages/app/src/index.ts"],
      "@ext-ts/fx": ["packages/fx/src/index.ts"],
      "@ext-ts/theme": ["packages/theme/src/index.ts"]
    }
  }
}
